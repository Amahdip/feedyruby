{
  "name": "@feedyruby/js-core",
  "private": true,
  "type": "module",
  "license": "MIT",
  "version": "1.0.0",
  "description": "Js core for FeedyRuby that contains the logic for executing the @feedyruby/js library and is loaded asynchronously over the FeedyRuby API.",
  "homepage": "https://feedyruby.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/feedyruby/feedyruby"
  },
  "keywords": [
    "FeedyRuby",
    "surveys",
    "experience management"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/index.js",
    "require": "./dist/index.umd.cjs"
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "scripts": {
    "dev": "vite build --watch --mode dev",
    "build": "vite build",
    "build:dev": "vite build --mode dev",
    "go": "vite build --watch --mode dev",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.js,.tsx,.jsx",
    "clean": "rimraf .turbo node_modules dist coverage",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "author": "FeedyRuby <hola@feedyruby.com>",
  "devDependencies": {
    "@feedyruby/config-typescript": "workspace:*",
    "@feedyruby/eslint-config": "workspace:*",
    "@vitest/coverage-v8": "4.1.6",
    "vite": "7.3.3",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.1.6"
  }
}
